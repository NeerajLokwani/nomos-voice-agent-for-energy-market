# --- Compliance: the ONLY number the agent may ever dial (the Nomos practice clerk) ---
# Set this to the practice-clerk number provided by Nomos. E.164 format, e.g. +49301234567
PRACTICE_CLERK_NUMBER=

# Twilio (places the actual call)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ElevenLabs Conversational AI
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

# Public base URL of this app (for Twilio + EL webhooks), e.g. an ngrok https URL
PUBLIC_BASE_URL=http://localhost:8000

# Where to persist call results (JSON store)
STORE_PATH=./data/results.json

# OpenAI — used ONLY by the Helga clerk simulator (sim/harness.py) for the dev loop.
# Not used by the production agent (its brain runs inside ElevenLabs).
OPENAI_API_KEY=
# Optional: override the simulator model (default gpt-5.5).
# Use gpt-5.4-mini for cheaper/faster iteration.
SIM_MODEL=gpt-5.5
